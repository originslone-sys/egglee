# Copie para .env e preencha. NUNCA versione o .env real.
DEEPSEEK_API_KEY=sk-sua-chave-aqui
# Opcionais (têm padrão sensato):
# Modelos atuais: deepseek-v4-flash (rápido) ou deepseek-v4-pro (mais capaz).
DEEPSEEK_MODEL=deepseek-v4-flash
# thinking mode: "disabled" (resposta direta, recomendado) ou "enabled".
DEEPSEEK_THINKING=disabled
# teto de tokens da geração (mais = artigo maior, porém mais lento).
DEEPSEEK_MAX_TOKENS=5000
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
SITE_URL=https://seu-dominio.com

# Imagens (Pexels) — crie grátis em https://www.pexels.com/api/
PEXELS_API_KEY=

# ---- Monetização e contato (opcionais) ----
# AdSense só carrega com o client preenchido E o visitante aceitando os cookies.
ADSENSE_CLIENT=
# Slot opcional, para o anúncio no meio do artigo (sem ele, use Auto Ads).
ADSENSE_SLOT=
# E-mail exibido nas páginas legais (privacidade, contato, etc.).
CONTACT_EMAIL=

# ---- MySQL ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASS=sua_senha

# Debug (mostra stack trace em erro 500). Use "0" em produção.
APP_DEBUG=0
