# Database (Cloud SQL MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=galinha_farm
DB_PASSWORD=your_password_here
DB_NAME=galinha_farm

# Cloud SQL — set this for Cloud Run (uses Unix socket instead of TCP)
# Format: project-id:region:instance-name
# CLOUD_SQL_CONNECTION_NAME=my-project:us-central1:galinha-farm-db

# JWT
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d

# Server
PORT=8080
NODE_ENV=production

# Admin wallet (for MetaMask auth)
ADMIN_WALLETS=0xYourAdminWalletAddress

# BEP20 RPC
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_CONFIRMATIONS=12
