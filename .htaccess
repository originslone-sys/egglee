# egglee — roteamento, proteção e cache (Apache / LiteSpeed / Hostinger)
# A raiz deste repositório é o document root (public_html).

RewriteEngine On

# 1) Bloqueia dotfiles e dotdirs (.env, .git, .htaccess...) — exceto .well-known
RewriteRule (^|/)\.(?!well-known)[^/]* - [F,L]

# 2) Bloqueia acesso web às pastas internas da aplicação
RewriteRule ^(app|views|database|scripts)(/|$) - [F,L]

# 3) Arquivos/pastas reais existentes (assets) são servidos direto
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4) Todo o resto vai para o front controller
RewriteRule ^ index.php [L]

# Reforço: nega acesso direto ao .env
<Files ".env">
  Require all denied
</Files>

# Cache de assets estáticos
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# Compressão
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
