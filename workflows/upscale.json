{
  "1": {
    "inputs": { "ckpt_name": "sdxl_checkpoint.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "inputs": {
      "lora_name": "detail_tweaker_xl.safetensors",
      "strength_model": 0.35,
      "strength_clip": 0.2,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Detail Tweaker XL" }
  },
  "3": {
    "inputs": {
      "lora_name": "skin_detail_xl.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["2", 0],
      "clip": ["2", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Skin Detail XL" }
  },
  "4": {
    "inputs": {
      "lora_name": "mobile_photography.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["3", 0],
      "clip": ["3", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Mobile Photography" }
  },
  "5": {
    "inputs": {
      "lora_name": "hand_fix_xl.safetensors",
      "strength_model": 0.5,
      "strength_clip": 0.0,
      "model": ["4", 0],
      "clip": ["4", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Hand Fix XL" }
  },
  "6": {
    "inputs": { "image": "{{input_image}}", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Selected Image" }
  },
  "7": {
    "inputs": { "model_name": "4x-UltraSharp.pth" },
    "class_type": "UpscaleModelLoader",
    "_meta": { "title": "Load Upscale Model" }
  },
  "8": {
    "inputs": { "upscale_model": ["7", 0], "image": ["6", 0] },
    "class_type": "ImageUpscaleWithModel",
    "_meta": { "title": "Upscale 4x" }
  },
  "9": {
    "inputs": { "upscale_method": "lanczos", "scale_by": 0.5, "image": ["8", 0] },
    "class_type": "ImageScaleBy",
    "_meta": { "title": "Resize to 2x" }
  },
  "10": {
    "inputs": { "pixels": ["9", 0], "vae": ["1", 2] },
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode" }
  },
  "11": {
    "inputs": { "text": "{{positive_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "12": {
    "inputs": { "text": "{{negative_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "13": {
    "inputs": {
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.35,
      "model": ["5", 0],
      "positive": ["11", 0],
      "negative": ["12", 0],
      "latent_image": ["10", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (refine)" }
  },
  "14": {
    "inputs": { "samples": ["13", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "15": {
    "inputs": { "filename_prefix": "upscale", "images": ["14", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
