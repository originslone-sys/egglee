{
  "1": {
    "inputs": { "ckpt_name": "{{checkpoint}}" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "20": {
    "inputs": {
      "lora_name": "egglee_character.safetensors",
      "strength_model": 0.85,
      "strength_clip": 0.8,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Personagem (egglee)" }
  },
  "2": {
    "inputs": {
      "lora_name": "detail_tweaker_xl.safetensors",
      "strength_model": 0.45,
      "strength_clip": 0.25,
      "model": ["20", 0],
      "clip": ["20", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Detail Tweaker XL" }
  },
  "3": {
    "inputs": {
      "lora_name": "skin_detail_xl.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["2", 0],
      "clip": ["2", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Skin Detail XL" }
  },
  "4": {
    "inputs": {
      "lora_name": "mobile_photography.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["3", 0],
      "clip": ["3", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Mobile Photography" }
  },
  "5": {
    "inputs": {
      "lora_name": "hand_fix_xl.safetensors",
      "strength_model": 0.5,
      "strength_clip": 0.0,
      "model": ["4", 0],
      "clip": ["4", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Hand Fix XL" }
  },
  "6": {
    "inputs": { "image": "{{input_image}}", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Selected Image" }
  },
  "7": {
    "inputs": { "upscale_method": "lanczos", "scale_by": 1.5, "image": ["6", 0] },
    "class_type": "ImageScaleBy",
    "_meta": { "title": "Pixel Upscale 1.5x (lanczos)" }
  },
  "8": {
    "inputs": { "pixels": ["7", 0], "vae": ["1", 2] },
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode" }
  },
  "9": {
    "inputs": { "text": "{{positive_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "10": {
    "inputs": { "text": "{{negative_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "11": {
    "inputs": {
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.32,
      "model": ["5", 0],
      "positive": ["9", 0],
      "negative": ["10", 0],
      "latent_image": ["8", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (refine)" }
  },
  "12": {
    "inputs": { "samples": ["11", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "13": {
    "inputs": { "model_name": "bbox/face_yolov8m.pt" },
    "class_type": "UltralyticsDetectorProvider",
    "_meta": { "title": "Face Detector" }
  },
  "14": {
    "inputs": {
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.40,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "detailed face, sharp detailed eyes, clear iris, natural skin texture",
      "cycle": 1,
      "image": ["12", 0],
      "model": ["5", 0],
      "clip": ["5", 1],
      "vae": ["1", 2],
      "positive": ["9", 0],
      "negative": ["10", 0],
      "bbox_detector": ["13", 0]
    },
    "class_type": "FaceDetailer",
    "_meta": { "title": "Face Detailer" }
  },
  "15": {
    "inputs": { "model_name": "bbox/hand_yolov8s.pt" },
    "class_type": "UltralyticsDetectorProvider",
    "_meta": { "title": "Hand Detector" }
  },
  "16": {
    "inputs": {
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.35,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "perfect hands, five fingers, detailed hand, natural fingers",
      "cycle": 1,
      "image": ["14", 0],
      "model": ["5", 0],
      "clip": ["5", 1],
      "vae": ["1", 2],
      "positive": ["9", 0],
      "negative": ["10", 0],
      "bbox_detector": ["15", 0]
    },
    "class_type": "FaceDetailer",
    "_meta": { "title": "Hand Detailer" }
  },
  "17": {
    "inputs": { "filename_prefix": "upscale", "images": ["16", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
