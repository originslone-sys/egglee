{
  "1": {
    "inputs": { "ckpt_name": "sdxl_checkpoint.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "inputs": {
      "lora_name": "detail_tweaker_xl.safetensors",
      "strength_model": 0.35,
      "strength_clip": 0.2,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Detail Tweaker XL" }
  },
  "3": {
    "inputs": {
      "lora_name": "skin_detail_xl.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["2", 0],
      "clip": ["2", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Skin Detail XL" }
  },
  "4": {
    "inputs": {
      "lora_name": "mobile_photography.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["3", 0],
      "clip": ["3", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Mobile Photography" }
  },
  "5": {
    "inputs": {
      "lora_name": "hand_fix_xl.safetensors",
      "strength_model": 0.5,
      "strength_clip": 0.0,
      "model": ["4", 0],
      "clip": ["4", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Hand Fix XL" }
  },
  "6": {
    "inputs": { "text": "{{positive_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "7": {
    "inputs": { "text": "{{negative_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "8": {
    "inputs": { "width": 832, "height": 1216, "batch_size": "{{batch_size}}" },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent" }
  },
  "9": {
    "inputs": {
      "seed": "{{seed}}",
      "steps": 30,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["5", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["8", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (base)" }
  },
  "12": {
    "inputs": {
      "upscale_method": "nearest-exact",
      "scale_by": 1.5,
      "samples": ["9", 0]
    },
    "class_type": "LatentUpscaleBy",
    "_meta": { "title": "Hires Upscale" }
  },
  "13": {
    "inputs": {
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.4,
      "model": ["5", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["12", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (hires)" }
  },
  "10": {
    "inputs": { "samples": ["13", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "11": {
    "inputs": { "filename_prefix": "txt2img_hd", "images": ["10", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
