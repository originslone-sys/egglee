{
  "1": {
    "inputs": { "ckpt_name": "sdxl_checkpoint.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "inputs": {
      "lora_name": "detail_tweaker_xl.safetensors",
      "strength_model": 0.35,
      "strength_clip": 0.2,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Detail Tweaker XL" }
  },
  "3": {
    "inputs": {
      "lora_name": "skin_detail_xl.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["2", 0],
      "clip": ["2", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Skin Detail XL" }
  },
  "4": {
    "inputs": {
      "lora_name": "mobile_photography.safetensors",
      "strength_model": 0.4,
      "strength_clip": 0.3,
      "model": ["3", 0],
      "clip": ["3", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Mobile Photography" }
  },
  "5": {
    "inputs": {
      "lora_name": "hand_fix_xl.safetensors",
      "strength_model": 0.5,
      "strength_clip": 0.0,
      "model": ["4", 0],
      "clip": ["4", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Hand Fix XL" }
  },
  "6": {
    "inputs": {
      "lora_name": "ip-adapter-faceid-plusv2_sdxl_lora.safetensors",
      "strength_model": 0.4,
      "model": ["5", 0]
    },
    "class_type": "LoraLoaderModelOnly",
    "_meta": { "title": "FaceID LoRA" }
  },
  "7": {
    "inputs": { "ipadapter_file": "ip-adapter-faceid-plusv2_sdxl.bin" },
    "class_type": "IPAdapterModelLoader",
    "_meta": { "title": "Load IPAdapter FaceID Model" }
  },
  "8": {
    "inputs": { "clip_name": "CLIP-ViT-H-14.safetensors" },
    "class_type": "CLIPVisionLoader",
    "_meta": { "title": "Load CLIP Vision" }
  },
  "9": {
    "inputs": { "provider": "CPU", "model_name": "buffalo_l" },
    "class_type": "IPAdapterInsightFaceLoader",
    "_meta": { "title": "Load InsightFace" }
  },
  "10": {
    "inputs": { "image": "{{face_image}}", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Reference Face" }
  },
  "11": {
    "inputs": {
      "weight": 0.75,
      "weight_faceidv2": 0.6,
      "weight_type": "linear",
      "combine_embeds": "average",
      "start_at": 0.0,
      "end_at": 0.75,
      "embeds_scaling": "K+V",
      "model": ["6", 0],
      "ipadapter": ["7", 0],
      "image": ["10", 0],
      "clip_vision": ["8", 0],
      "insightface": ["9", 0]
    },
    "class_type": "IPAdapterFaceID",
    "_meta": { "title": "Apply IPAdapter FaceID" }
  },
  "12": {
    "inputs": { "text": "{{positive_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "13": {
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["5", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "14": {
    "inputs": { "width": 832, "height": 1216, "batch_size": "{{batch_size}}" },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent" }
  },
  "15": {
    "inputs": {
      "seed": "{{seed}}",
      "steps": 30,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["11", 0],
      "positive": ["12", 0],
      "negative": ["13", 0],
      "latent_image": ["14", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" }
  },
  "16": {
    "inputs": { "samples": ["15", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "18": {
    "inputs": { "model_name": "bbox/face_yolov8m.pt" },
    "class_type": "UltralyticsDetectorProvider",
    "_meta": { "title": "Face Detector" }
  },
  "19": {
    "inputs": {
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": "{{seed}}",
      "steps": 25,
      "cfg": 4.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 0.45,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1,
      "image": ["16", 0],
      "model": ["11", 0],
      "clip": ["5", 1],
      "vae": ["1", 2],
      "positive": ["12", 0],
      "negative": ["13", 0],
      "bbox_detector": ["18", 0]
    },
    "class_type": "FaceDetailer",
    "_meta": { "title": "Face Detailer (FaceID)" }
  },
  "17": {
    "inputs": { "filename_prefix": "faceid", "images": ["19", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
