{
  "1": {
    "inputs": { "ckpt_name": "sdxl_checkpoint.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "inputs": {
      "lora_name": "detail_tweaker_xl.safetensors",
      "strength_model": 0.7,
      "strength_clip": 0.7,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Detail Tweaker XL" }
  },
  "3": {
    "inputs": {
      "lora_name": "skin_detail_xl.safetensors",
      "strength_model": 0.6,
      "strength_clip": 0.6,
      "model": ["2", 0],
      "clip": ["2", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Skin Detail XL" }
  },
  "4": {
    "inputs": {
      "lora_name": "mobile_photography.safetensors",
      "strength_model": 0.5,
      "strength_clip": 0.5,
      "model": ["3", 0],
      "clip": ["3", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Mobile Photography" }
  },
  "5": {
    "inputs": {
      "lora_name": "hand_fix_xl.safetensors",
      "strength_model": 0.7,
      "strength_clip": 0.7,
      "model": ["4", 0],
      "clip": ["4", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "LoRA - Hand Fix XL" }
  },
  "6": {
    "inputs": {
      "lora_name": "ip-adapter-faceid-plusv2_sdxl_lora.safetensors",
      "strength_model": 0.6,
      "model": ["5", 0]
    },
    "class_type": "LoraLoaderModelOnly",
    "_meta": { "title": "FaceID LoRA" }
  },
  "7": {
    "inputs": { "ipadapter_file": "ip-adapter-faceid-plusv2_sdxl.bin" },
    "class_type": "IPAdapterModelLoader",
    "_meta": { "title": "Load IPAdapter FaceID Model" }
  },
  "8": {
    "inputs": { "clip_name": "CLIP-ViT-H-14.safetensors" },
    "class_type": "CLIPVisionLoader",
    "_meta": { "title": "Load CLIP Vision" }
  },
  "9": {
    "inputs": { "provider": "CPU", "model_name": "buffalo_l" },
    "class_type": "IPAdapterInsightFaceLoader",
    "_meta": { "title": "Load InsightFace" }
  },
  "10": {
    "inputs": { "image": "{{face_image}}", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Reference Face" }
  },
  "11": {
    "inputs": {
      "weight": 1.0,
      "weight_faceidv2": 1.0,
      "weight_type": "linear",
      "combine_embeds": "average",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "K+V",
      "model": ["6", 0],
      "ipadapter": ["7", 0],
      "image": ["10", 0],
      "clip_vision": ["8", 0],
      "insightface": ["9", 0]
    },
    "class_type": "IPAdapterFaceID",
    "_meta": { "title": "Apply IPAdapter FaceID" }
  },
  "12": {
    "inputs": { "text": "{{positive_prompt}}", "clip": ["5", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "13": {
    "inputs": {
      "text": "worst quality, low quality, blurry, deformed, ugly, disfigured, bad anatomy, bad hands, extra fingers, missing fingers, watermark, signature, text",
      "clip": ["5", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "14": {
    "inputs": { "width": 1024, "height": 1024, "batch_size": 1 },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent" }
  },
  "15": {
    "inputs": {
      "seed": "{{seed}}",
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["11", 0],
      "positive": ["12", 0],
      "negative": ["13", 0],
      "latent_image": ["14", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" }
  },
  "16": {
    "inputs": { "samples": ["15", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "17": {
    "inputs": { "filename_prefix": "faceid", "images": ["16", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
