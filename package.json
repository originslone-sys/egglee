{
  "name": "galinha-farm",
  "version": "1.0.0",
  "description": "Galinha Farm — Smart Poultry Simulation Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "migrate": "knex migrate:latest --knexfile server/config/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile server/config/knexfile.js",
    "seed": "knex seed:run --knexfile server/config/knexfile.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0",
    "node-cron": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
