---
import { HREFLANG, UI } from '../i18n/ui.mjs';

/**
 * Shell base: <head> com SEO, hreflang alternates e canonical.
 * `alternates` = mapa { pt: '/pt/slug', es: '/es/slug', en: '/en/slug' }
 * para o mesmo símbolo (ajuda o Google a entender as versões por idioma).
 */
const {
  lang,
  title,
  description,
  canonicalPath,
  alternates = {},
  jsonLd = [],
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = `${site}${canonicalPath}`;
---

<!doctype html>
<html lang={HREFLANG[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {
      Object.entries(alternates).map(([l, path]) => (
        <link rel="alternate" hreflang={HREFLANG[l]} href={`${site}${path}`} />
      ))
    }
    {alternates.pt && <link rel="alternate" hreflang="x-default" href={`${site}${alternates.pt}`} />}

    <!-- Open Graph básico -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <!-- Identidade visual -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1c1745" />

    <!-- Fontes: Fraunces (títulos) + Nunito (corpo) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Nunito:wght@400;700&display=swap"
      rel="stylesheet"
    />

    {
      jsonLd.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }

    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="foot-brand">egglee</p>
        <p class="disclaimer">{UI[lang].disclaimer}</p>
        <p class="disclaimer">© {new Date().getFullYear()} egglee</p>
      </div>
    </footer>
  </body>
</html>
