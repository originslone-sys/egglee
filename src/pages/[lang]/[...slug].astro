---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { UI } from '../../i18n/ui.mjs';

export async function getStaticPaths() {
  const LANGS = ['pt', 'es', 'en'];
  const all = await getCollection('symbols');
  // QUALIDADE GATE: drafts não geram página. Só revisado/publicado vai ao ar.
  const live = all.filter((e) => e.data.status !== 'draft');

  // Índice id -> registro, para montar links relacionados e alternates.
  const byId = new Map(live.map((e) => [e.data.id, e.data]));

  const paths = [];
  for (const entry of live) {
    const { id, languages, related } = entry.data;
    for (const lang of LANGS) {
      const content = languages[lang];

      // Alternates: mesmo símbolo em cada idioma.
      const alternates = {};
      for (const l of LANGS) alternates[l] = `/${l}/${languages[l].slug}`;

      // Links relacionados resolvidos no mesmo idioma.
      const relatedLinks = related
        .map((rid) => byId.get(rid))
        .filter(Boolean)
        .map((r) => ({ href: `/${lang}/${r.languages[lang].slug}`, label: r.languages[lang].h1 }));

      paths.push({
        params: { lang, slug: content.slug },
        props: { lang, content, alternates, relatedLinks, category: entry.data.category },
      });
    }
  }
  return paths;
}

const { lang, content, alternates, relatedLinks } = Astro.props;
const t = UI[lang];
const canonicalPath = `/${lang}/${content.slug}`;
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';

// ---- Schema.org: Article + FAQPage + Breadcrumb ----
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: content.h1,
  description: content.metaDescription,
  inLanguage: lang,
  mainEntityOfPage: `${site}${canonicalPath}`,
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.home, item: `${site}/${lang}` },
    { '@type': 'ListItem', position: 2, name: content.h1 },
  ],
};
---

<Base
  lang={lang}
  title={content.title}
  description={content.metaDescription}
  canonicalPath={canonicalPath}
  alternates={alternates}
  jsonLd={[articleSchema, faqSchema, breadcrumbSchema]}
>
  <Header lang={lang} alternates={alternates} />

  <main class="wrap article">
    <p class="breadcrumbs"><a href={`/${lang}`}>{t.home}</a> › {content.h1}</p>
    <h1>{content.h1}</h1>

    <aside class="quick-answer">
      <strong>{t.quickAnswerLabel}:</strong>
      <p>{content.quickAnswer}</p>
    </aside>

    <div class="intro" set:html={content.intro.split('\n').map((p) => `<p>${p}</p>`).join('')} />

    {content.sections.map((s) => (
      <section>
        <h2>{s.heading}</h2>
        <p>{s.body}</p>
      </section>
    ))}

    <section>
      <h2>{t.variationsTitle}</h2>
      <ul class="variations">
        {content.variations.map((v) => (
          <li><strong>{v.keyword}:</strong> {v.meaning}</li>
        ))}
      </ul>
    </section>

    <section class="faq">
      <h2>{t.faqTitle}</h2>
      {content.faq.map((f) => (
        <details>
          <summary>{f.question}</summary>
          <p>{f.answer}</p>
        </details>
      ))}
    </section>

    <p class="closing">{content.closing}</p>

    {relatedLinks.length > 0 && (
      <nav class="related">
        <h2>{t.relatedTitle}</h2>
        <ul>
          {relatedLinks.map((r) => <li><a href={r.href}>{r.label}</a></li>)}
        </ul>
      </nav>
    )}
  </main>
</Base>
