---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { UI } from '../../i18n/ui.mjs';

export async function getStaticPaths() {
  const LANGS = ['pt', 'es', 'en'];
  return LANGS.map((lang) => ({ params: { lang }, props: { lang } }));
}

const LANGS = ['pt', 'es', 'en'];
const { lang } = Astro.props;
const t = UI[lang];

const all = await getCollection('symbols');
const live = all.filter((e) => e.data.status !== 'draft');
const items = live
  .map((e) => ({ href: `/${lang}/${e.data.languages[lang].slug}`, label: e.data.languages[lang].h1 }))
  .sort((a, b) => a.label.localeCompare(b.label));

const alternates = Object.fromEntries(LANGS.map((l) => [l, `/${l}`]));
---

<Base
  lang={lang}
  title={`egglee — ${t.tagline}`}
  description={t.tagline}
  canonicalPath={`/${lang}`}
  alternates={alternates}
>
  <Header lang={lang} alternates={alternates} />

  <section class="hero">
    <div class="hero__inner">
      <img class="egg-mark" src="/favicon.svg" alt="" width="64" height="64" />
      <h1>{t.heroTitle}</h1>
      <p class="tagline">{t.tagline}</p>
    </div>
  </section>

  <main class="wrap-wide">
    <h2 class="section-title">{t.indexTitle}</h2>
    <p class="section-sub">{t.indexSub}</p>
    <ul class="card-grid">
      {items.map((i) => (
        <li>
          <a class="card" href={i.href}><span class="dot" aria-hidden="true"></span>{i.label}</a>
        </li>
      ))}
    </ul>
  </main>
</Base>
