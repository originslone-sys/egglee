---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { UI } from '../../i18n/ui.mjs';

export async function getStaticPaths() {
  const LANGS = ['pt', 'es', 'en'];
  return LANGS.map((lang) => ({ params: { lang }, props: { lang } }));
}

const LANGS = ['pt', 'es', 'en'];

const { lang } = Astro.props;
const t = UI[lang];

const all = await getCollection('symbols');
const live = all.filter((e) => e.data.status !== 'draft');
const items = live
  .map((e) => ({ href: `/${lang}/${e.data.languages[lang].slug}`, label: e.data.languages[lang].h1 }))
  .sort((a, b) => a.label.localeCompare(b.label));

const alternates = Object.fromEntries(LANGS.map((l) => [l, `/${l}`]));
---

<Base
  lang={lang}
  title={`${t.siteName} — ${t.tagline}`}
  description={t.tagline}
  canonicalPath={`/${lang}`}
  alternates={alternates}
>
  <header class="topbar">
    <a href={`/${lang}`}>{t.siteName}</a>
    <nav class="langs">
      {LANGS.map((l) => (
        <a href={`/${l}`} aria-current={l === lang ? 'page' : undefined}>{UI[l].langName}</a>
      ))}
    </nav>
  </header>
  <main class="article">
    <h1>{t.siteName}</h1>
    <p class="tagline">{t.tagline}</p>
    <ul class="index-list">
      {items.map((i) => <li><a href={i.href}>{i.label}</a></li>)}
    </ul>
  </main>
</Base>
